# 服务器端口
SERVER_PORT=3000

# OpenClaw Gateway 配置（选一种即可）

# 方式 1：自动检测（推荐）
# 不配置任何值，框架会自动尝试常见端口：18789, 19000, 8080, 9000

# 方式 2：指定端口
OPENCLAW_GATEWAY_PORT=19000

# 方式 3：完整地址
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:19000

# 方式 4：远程 Gateway
# OPENCLAW_GATEWAY_HOST=192.168.1.100
# OPENCLAW_GATEWAY_PORT=19000

# 会话配置
# SESSION_MODE=memory  # 或 redis
# SESSION_TIMEOUT=3600000  # 1 小时，单位毫秒

# 日志级别
# LOG_LEVEL=info  # debug, info, warn, error
